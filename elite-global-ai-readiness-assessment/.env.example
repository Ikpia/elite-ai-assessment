# Optional absolute backend URL for deployed environments.
# Leave unset in local development and Vite will proxy /api to VITE_API_PROXY_TARGET.
VITE_API_BASE_URL=

# Local development proxy target for the backend service in ../backend.
VITE_API_PROXY_TARGET=http://localhost:4000

# External marketing site used by completion CTA.
VITE_MARKETING_SITE_URL=https://eliteglobalai.com
